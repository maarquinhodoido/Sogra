generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("MANAGER")
  isActive     Boolean   @default(true)
  notes        String?   @db.NVarChar(Max)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SiteSettings {
  id                     String   @id @default(cuid())
  businessName           String
  tagline                String
  businessEmail          String
  bookingEmail           String
  phone                  String
  whatsapp               String
  address                String
  city                   String
  postalCode             String
  googleMapsUrl          String
  instagramUrl           String?
  facebookUrl            String?
  tiktokUrl              String?
  heroImageUrl           String?
  logoUrl                String?
  faviconUrl             String?
  bookingBufferMinutes   Int      @default(15)
  maxAppointmentsPerDay  Int      @default(12)
  allowDeposits          Boolean  @default(false)
  depositAmount          Decimal? @db.Decimal(10, 2)
  loyaltyEnabled         Boolean  @default(false)
  couponsEnabled         Boolean  @default(false)
  metaTitle              String?
  metaDescription        String?  @db.NVarChar(1000)
  metaKeywords           String?  @db.NVarChar(1000)
  consentLabel           String   @default("Li e aceito a política de privacidade e o tratamento dos meus dados para efeitos de contacto e marcação.")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PageContent {
  id              String   @id @default(cuid())
  slug            String
  sectionKey      String
  title           String
  subtitle        String?
  content         String?  @db.NVarChar(Max)
  imageUrl        String?
  ctaLabel        String?
  ctaHref         String?
  metaTitle       String?
  metaDescription String?  @db.NVarChar(1000)
  metaKeywords    String?  @db.NVarChar(1000)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([slug, sectionKey])
}

model Banner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  ctaLabel   String?
  ctaHref    String?
  placement  String
  isActive   Boolean  @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.NVarChar(1000)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
}

model Service {
  id              String                @id @default(cuid())
  categoryId      String
  name            String
  slug            String                @unique
  description     String                @db.NVarChar(2000)
  durationMinutes Int
  price           Decimal               @db.Decimal(10, 2)
  imageUrl        String?
  isActive        Boolean               @default(true)
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  category        ServiceCategory       @relation(fields: [categoryId], references: [id])
  professionals   ProfessionalService[]
  appointments    Appointment[]
}

model Professional {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  specialty        String
  bio              String                @db.NVarChar(2000)
  email            String?
  phone            String?
  imageUrl         String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  services         ProfessionalService[]
  businessHours    BusinessHour[]
  timeOffs         TimeOff[]
  appointments     Appointment[]
}

model ProfessionalService {
  professionalId String
  serviceId      String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
}

model BusinessHour {
  id             String        @id @default(cuid())
  weekday        Int
  opensAt        String
  closesAt       String
  breakStart     String?
  breakEnd       String?
  isClosed       Boolean       @default(false)
  professionalId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
}

model TimeOff {
  id             String        @id @default(cuid())
  title          String
  reason         String?       @db.NVarChar(1000)
  startsAt       DateTime
  endsAt         DateTime
  isAllDay       Boolean       @default(true)
  professionalId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String
  notes        String?       @db.NVarChar(Max)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Appointment {
  id             String            @id @default(cuid())
  customerId     String
  serviceId      String
  professionalId String
  startAt        DateTime
  endAt          DateTime
  status         String            @default("PENDING")
  clientNotes    String?           @db.NVarChar(2000)
  internalNotes  String?           @db.NVarChar(2000)
  manageToken    String            @unique
  source         String            @default("site")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  customer       Customer          @relation(fields: [customerId], references: [id])
  service        Service           @relation(fields: [serviceId], references: [id])
  professional   Professional      @relation(fields: [professionalId], references: [id])
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  altText     String?
  description String?  @db.NVarChar(1000)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id         String   @id @default(cuid())
  title      String
  fileName   String
  filePath   String
  altText    String?
  kind       String
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  rating      Int
  comment     String   @db.NVarChar(2000)
  serviceName String?
  isApproved  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.NVarChar(2000)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  description String   @db.NVarChar(2000)
  badge       String?
  ctaLabel    String?
  ctaHref     String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String   @db.NVarChar(2000)
  consent    Boolean  @default(false)
  replied    Boolean  @default(false)
  createdAt  DateTime @default(now())
}
